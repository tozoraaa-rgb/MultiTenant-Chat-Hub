# ------------------------------
# Service runtime
# ------------------------------
NODE_ENV=development
PORT=4000

# ------------------------------
# MySQL / Sequelize connection
# ------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=chatbot_db

# Optional startup bootstrap behavior (useful for Docker local stacks)
DB_AUTO_SYNC=false
DB_AUTO_SEED=false
DB_CONNECT_RETRY_ATTEMPTS=10
DB_CONNECT_RETRY_DELAY_MS=3000

# ------------------------------
# Auth / token configuration
# ------------------------------
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN_SECONDS=3600

# ------------------------------
# Seed data bootstrap (optional, for `npm run seed`)
# ------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_DEMO_CHATBOT_DOMAIN=shop.example.com

# ------------------------------
# Public chat runtime (Gemini)
# Required for /api/v1/public/chat
# ------------------------------
GEMINI_API_KEY=replace_with_gemini_api_key

# ------------------------------
# Public runtime security / CORS
# ------------------------------
# For non-production only: allow public runtime calls without Origin header.
PUBLIC_RUNTIME_ALLOW_MISSING_ORIGIN=false

## Optional production/browser CORS allowlist (comma-separated origins)
# Example: https://shop.example.com,https://www.shop.example.com
# Use * to allow all origins (quick testing only; not recommended for production)
CORS_ALLOWED_ORIGINS=
