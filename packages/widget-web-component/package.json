{
  "name": "@mth/widget-web-component",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "build:browser": "node ../../scripts/ensure-windows-optional-deps.mjs && npm run build --workspace @mth/shared-types && npm run build --workspace @mth/widget-core && npm run build --workspace @mth/widget-react && esbuild src/browser.ts --bundle --format=iife --global-name=MTHChatbotWidget --outfile=dist/chatbot-widget.browser.js"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@mth/widget-react": "*"
  },
  "devDependencies": {
    "@mth/eslint-config": "*",
    "@mth/tsconfig-base": "*",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^24.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "esbuild": "^0.25.9"
  },
  "type": "module"
}
